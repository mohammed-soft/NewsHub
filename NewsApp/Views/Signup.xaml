<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NewsApp.Views.Signup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Signup">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Label
                FontAttributes="Bold"
                FontSize="28"
                HorizontalOptions="Center"
                Text="Create Account" />

            <Entry
                x:Name="NameEntry"
                Keyboard="Default"
                Placeholder="Full Name" />


            <Entry
                x:Name="emailEntry"
                Keyboard="Email"
                Placeholder="Email" />

            <Entry
                x:Name="passwordEntry"
                IsPassword="True"
                Placeholder="Password" />

            <Button
                Clicked="OnSignUpClicked"
                Text="Sign Up"
                TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>