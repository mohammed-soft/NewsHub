<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NewsApp.Views.Profile"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profile"
    Shell.NavBarIsVisible="False">

    <VerticalStackLayout
        Padding="30"
        Spacing="20"
        VerticalOptions="Center">
        <VerticalStackLayout x:Name="NoUser">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Welcome to NewsHub" />

            <Button
                Margin="0,8"
                Clicked="OnSignupClicked"
                Text="Sign up"
                TextColor="White" />

            <Button
                Clicked="OnSigninClicked"
                Text="Sign in"
                TextColor="White" />
        </VerticalStackLayout>
        <VerticalStackLayout x:Name="UserSignedin">
            <Label
                x:Name="welcomeLabel"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Welcome to NewsHub" />

            <Button
                Margin="0,8"
                BackgroundColor="Red"
                Clicked="OnSignoutClicked"
                Text="Signout"
                TextColor="White" />

        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>